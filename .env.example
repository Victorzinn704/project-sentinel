APP_ENV=development
HTTP_ADDR=:8080
SESSION_STORE_PATH=./sessions
STATE_DB_PATH=./sessions/state.db
MODELS_CONFIG_PATH=./configs/models.json
LOG_LEVEL=info
ROTATION_STRATEGY=quota_first
QUOTA_REFRESH_INTERVAL_SECONDS=300
DEFAULT_MODEL=sentinel-router
DEFAULT_REASONING_EFFORT=auto
CODEX_REASONING_EFFORT=xhigh
CODEX_BASE_URL=https://app.deskimperial.online/suporte/v1
SENTINEL_PUBLIC_HOST=app.deskimperial.online
SENTINEL_PUBLIC_PREFIX=/suporte
LETSENCRYPT_EMAIL=ops@example.com
REQUEST_TIMEOUT_SECONDS=120
MAX_ATTEMPTS=3
SENTINEL_API_KEY=sk-sentinel-replace-with-a-random-local-api-key
SENTINEL_ADMIN_API_KEY=sk-sentinel-admin-replace-with-a-different-random-local-api-key

# Must be exactly 32 bytes. Generate your own and back it up in a password manager.
SESSION_ENCRYPTION_KEY=change-this-key-32-bytes-long!!!
